# =============================================================================
# Cross-Exchange Bot — Environment Variables
# =============================================================================
# Copy to .env and fill in your credentials.  NEVER commit .env to git.
#
# Required (missing = fail-fast on startup):
#   EDGEX_BASE_URL, EDGEX_ACCOUNT_ID, EDGEX_STARK_PRIVATE_KEY
#   LIGHTER_BASE_URL, LIGHTER_WS_URL, LIGHTER_PRIVATE_KEY
#
# Optional (reasonable defaults provided):
#   ACCOUNT_INDEX / LIGHTER_ACCOUNT_INDEX  → default 0
#   API_KEY_INDEX / LIGHTER_API_KEY_INDEX  → default 0
# =============================================================================

# ---- EdgeX ----
EDGEX_BASE_URL=https://pro.edgex.exchange
EDGEX_ACCOUNT_ID=
EDGEX_STARK_PRIVATE_KEY=

# ---- Lighter ----
LIGHTER_BASE_URL=https://mainnet.zklighter.elliot.ai
LIGHTER_WS_URL=wss://mainnet.zklighter.elliot.ai/stream
LIGHTER_PRIVATE_KEY=

# ---- Lighter account (optional, defaults to 0) ----
LIGHTER_ACCOUNT_INDEX=0
LIGHTER_API_KEY_INDEX=0

# ---- Hyperliquid ----
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz
HYPERLIQUID_PRIVATE_KEY=
# Main trading account address (the API wallet trades on behalf of this account)
HYPERLIQUID_ACCOUNT_ADDRESS=

# ---- GRVT ----
GRVT_TRADING_ACCOUNT_ID=
GRVT_PRIVATE_KEY=
GRVT_API_KEY=
GRVT_ENV=testnet

# ---- Exchange Selection ----
# Comma-separated list of exchange IDs to activate (minimum 2)
ACTIVE_EXCHANGES=edgex,lighter

# ---- Legacy fallback names (same order of precedence) ----
# ACCOUNT_INDEX=0
# API_KEY_INDEX=0
# API_KEY_PRIVATE_KEY=
